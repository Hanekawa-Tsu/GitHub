@model ActividadJulio17.Models.Estudiante[]

@{
    ViewData["Title"] = "Listado de Estudiantes";
}

<h1>Listado de Estudiantes</h1>

<a class="btn btn-primary mb-3" asp-controller="Estudiante" asp-action="Registrar">
    Registrar nuevo estudiante
</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Carnet</th>
            <th>Nombre</th>
            <th>Promedio</th>
            <th>Historial</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var estudiante in Model)
        {
            if (estudiante != null)
            {
                <tr>
                    <td>@estudiante.Carnet</td>
                    <td>@estudiante.Nombre</td>
                    <td>@estudiante.Promedio</td>
                    <td>
                        <a asp-controller="Estudiante"
                            asp-action="Historial"
                            asp-route-id="@estudiante.Carnet">
                            Ver historial
                        </a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>